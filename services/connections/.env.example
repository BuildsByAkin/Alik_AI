# alik connections (people-matching) service — environment.
# Copy to .env and fill in.

# This service's own Postgres (all match state lives here — never the brain's DBs).
DATABASE_URL=postgresql://alik:alik@localhost:5434/connections

# The companion brain's base URL — the ONLY way we read about a user (the Profile API).
BRAIN_URL=http://localhost:8000

# The auth service's base URL — the ingest roster (which user_ids exist, by state).
AUTH_URL=http://localhost:8001

# Ingest schedule (APScheduler cron). Default: every 6 hours.
INGEST_CRON=0 */6 * * *

# Scoring schedule (APScheduler cron). Default: nightly at 02:00, after ingest.
SCORE_CRON=0 2 * * *

# Comma-separated 2-letter state codes to ingest (auth enforces the real launch gate).
LAUNCH_STATES=MN

# Kernel weights/thresholds (overridable; sensible defaults in Settings).
# INTEREST_WEIGHT=0.5
# DIMENSION_WEIGHT=0.35
# VALUES_WEIGHT=0.15
# CONFIDENCE_REVIEW_THRESHOLD=0.5

# Shared service-to-service secret. Must equal the brain's ALIK_SERVICE_TOKEN (and the
# auth/matching services' SERVICE_TOKEN) so the mesh can authenticate each other.
SERVICE_TOKEN=change-me-to-a-long-random-string

# Port for THIS service (brain 8000, auth 8001, matching 8002, connections 8003).
PORT=8003

# Cross-evaluation model (used in Part 4; cheap/Haiku-class, never hardcoded).
LLM_MODEL=claude-haiku-4-5-20251001

# Age handling knob (used in Part 3): off | soft | hard. 25+ is already gated at signup.
AGE_FILTER_MODE=soft
