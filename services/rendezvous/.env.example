# alik rendezvous (meeting-coordination) service — environment. Copy to .env and fill in.

# This service's own Postgres (all meet state lives here — never the brain's DBs).
DATABASE_URL=postgresql://alik:alik@localhost:5435/rendezvous

# The companion brain's base URL — queue coordination check-ins + record social events.
BRAIN_URL=http://localhost:8000

# Shared service-to-service secret. Must equal the brain's ALIK_SERVICE_TOKEN (and the other
# services' SERVICE_TOKEN) so the mesh can authenticate each other.
SERVICE_TOKEN=change-me-to-a-long-random-string

# Advance-pass schedule (APScheduler cron). Default: every 30 minutes.
ADVANCE_CRON=*/30 * * * *

# Port for THIS service (brain 8000, auth 8001, matching 8002, connections 8003, rendezvous 8004).
PORT=8004
