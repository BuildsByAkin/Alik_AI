# alik Auth + Profile service — environment (prefix: SUPABASE_ for the three keys).
# Copy to .env and fill in from your Supabase project (Settings → API).
#
# IMPORTANT one-time Supabase setup: disable email confirmation so signup returns a
# live session immediately — Auth → Providers → Email → uncheck "Confirm email".

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Port for THIS service. The companion brain API runs on 8000 — keep these distinct.
PORT=8001

# Shared secret for the service-to-service /internal endpoints (identity reads for the
# living profile + cross-service account erasure). The brain must send the SAME value as
# its ALIK_AUTH_SERVICE_TOKEN. Generate one with: python -c "import secrets;print(secrets.token_urlsafe(32))"
SERVICE_TOKEN=change-me-to-a-long-random-string
