# alik matching service — environment.
# Copy to .env and fill in.

# This service's own Postgres (the recommendation log + per-user engagement flag).
DATABASE_URL=postgresql://alik:alik@localhost:5433/matching

# The companion brain's base URL — scoring reads the assembled living profile from it.
BRAIN_URL=http://localhost:8000

# Shared service-to-service secret. Must equal the brain's ALIK_SERVICE_TOKEN (and the
# auth service's SERVICE_TOKEN) so the mesh can authenticate each other.
SERVICE_TOKEN=change-me-to-a-long-random-string

# Port for THIS service (brain=8000, auth=8001, matching=8002).
PORT=8002

# Source-of-truth job catalog.
CATALOG_PATH=data/jobs.json
